# Godot 4+ specific ignores
.godot/

# Android build
/android/

# iOS/macOS builds
*.ipa
*.dSYM.zip
*.dSYM

# Windows builds
*.exe
*.msi

# Build outputs
/build/
/dist/
exports/

# Import cache (stored in .godot/)
# Note: *.import files should be committed - they contain asset metadata

# Editor-specific files
# Keep project.godot but ignore editor metadata
# .godot/ already handles most editor files

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# IDE/Editor
.vscode/
.idea/
*.swp
*.swo
*~

# Logs and databases
*.log
*.sql
*.sqlite

# Temporary files
*.tmp
*.temp
*.bak
*.cache

# Environment/Secrets (never commit these)
.env
.env.*
*.secret
*.credentials
*.pem
*.key
credentials.json

# Claude Code local memory (session-specific, not for repo)
# Note: .claude/ is intentionally tracked for team skill sharing

# Test outputs
test-results/
coverage/

# Package management
*.gdignore